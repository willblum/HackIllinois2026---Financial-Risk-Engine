# Modal (embedding only — LLM is served by Cerebras)
MODAL_APP_NAME=model-risk-llm

# Cerebras (LLM inference — get a free key at https://cloud.cerebras.ai)
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.1-8b

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=narratives

# Narrative routing (cosine distance threshold [0-2])
NEW_NARRATIVE_THRESHOLD=0.40

# ---------------------------------------------------------------
# Data sources  (leave blank to disable that source)
# ---------------------------------------------------------------

# NewsAPI — get a free key at https://newsapi.org/register
# Free tier: 100 requests/day, articles up to 1 month old
NEWSAPI_KEY=

# Twitter/X API v2 — bearer token from https://developer.twitter.com
# Requires a project + app with Read permissions (free Basic tier is fine)
TWITTER_BEARER_TOKEN=

# ---------------------------------------------------------------
# Background pipeline controls
# ---------------------------------------------------------------

# How often the background pipeline polls (seconds)
POLL_INTERVAL_SECONDS=300

# How far back each auto-poll looks (minutes)
# Keep this roughly equal to POLL_INTERVAL_SECONDS/60 to avoid gaps or overlaps
PIPELINE_LOOKBACK_MINUTES=10

# Max stories fetched per source per auto-poll
PIPELINE_MAX_PER_SOURCE=30

# Sources enabled for auto-polling (JSON list)
PIPELINE_SOURCES=["newsapi","twitter"]
